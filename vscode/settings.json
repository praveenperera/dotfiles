{
  "git-graph.openNewTabEditorGroup": "Two",
  "git-graph.retainContextWhenHidden": true,
  "vim.handleKeys": {
    "<C-h>": false,
    "<C-l>": false
  },
  "workbench.editor.openSideBySideDirection": "right",
  "chatgpt.openOnStartup": true,
  "diffEditor.renderSideBySide": true,
  "diffEditor.hideUnchangedRegions.contextLineCount": 8,
  "workbench.colorTheme": "Atom One Dark",
  "editor.accessibilitySupport": "off",
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.minimap.enabled": false,
  "vim.leader": "<space>",
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "f", "i"],
      "commands": ["actions.find"]
    },
    {
      "before": ["<leader>", "f", "w"],
      "commands": ["workbench.action.quickTextSearch"]
    },
    {
      "before": ["<leader>", "f", "f"],
      "commands": ["workbench.action.quickOpen"]
    },
    {
      "before": ["<leader>", "f", "p"],
      "commands": ["workbench.action.openRecent"]
    },
    {
      "before": ["<leader>", "f", "s"],
      "commands": ["workbench.action.gotoSymbol"]
    },
    {
      "before": ["<leader>", "f", "S"],
      "commands": ["workbench.action.showAllSymbols"]
    },
    {
      "before": ["<leader>", "l", "a"],
      "commands": ["editor.action.quickFix"]
    },
    {
      "before": ["<leader>", "l", "d"],
      "commands": ["editor.action.showHover"]
    },
    {
      "before": ["<leader>", "l", "D"],
      "commands": ["workbench.actions.view.problems"]
    },
    {
      "before": ["<leader>", "l", "f"],
      "commands": ["editor.action.formatDocument"]
    },
    {
      "before": ["<leader>", "l", "h"],
      "commands": ["editor.action.triggerParameterHints"]
    },
    {
      "before": ["<leader>", "l", "r"],
      "commands": ["editor.action.rename"]
    },
    {
      "before": ["<leader>", "l", "R"],
      "commands": ["editor.action.referenceSearch.trigger"]
    },
    {
      "before": ["<leader>", "l", "s"],
      "commands": ["workbench.action.gotoSymbol"]
    },
    {
      "before": ["<leader>", "l", "G"],
      "commands": ["workbench.action.showAllSymbols"]
    },
    {
      "before": ["<leader>", "u", "h"],
      "commands": ["editor.action.inlayHints.toggle"]
    },
    {
      "before": ["<leader>", "w"],
      "commands": ["workbench.action.files.save"]
    }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "l", "a"],
      "commands": ["editor.action.quickFix"]
    },
    {
      "before": ["<leader>", "l", "f"],
      "commands": ["editor.action.formatSelection"]
    }
  ],
  "vim.commandLineModeKeyBindingsNonRecursive": [
    {
      "before": ["e", "<CR>"],
      "commands": ["workbench.action.files.revert"],
      "silent": true
    }
  ],
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false
  },
  "rust-analyzer.inlayHints.typeHints.enable": false,
  "[rust]": {
    "editor.inlayHints.enabled": "off"
  }
}
