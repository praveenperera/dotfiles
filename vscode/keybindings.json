[
  {
    "key": "ctrl+l",
    "command": "chatgpt.openSidebar",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+h",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "webviewId == 'chatgpt.sidebarView' || webviewId == 'chatgpt.sidebarSecondaryView'"
  },
  {
    "key": "cmd+h",
    "command": "workbench.view.scm",
    "when": "editorTextFocus && activeEditorGroupIndex == 1"
  },
  {
    "key": "cmd+h",
    "command": "workbench.action.focusFirstEditorGroup",
    "when": "!editorTextFocus || activeEditorGroupIndex != 1"
  },
  {
    "key": "cmd+l",
    "command": "chatgpt.openSidebar",
    "when": "editorTextFocus"
  },
  {
    "key": "cmd+l",
    "command": "workbench.action.focusFirstEditorGroup",
    "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
  },
  {
    "key": "cmd+g",
    "command": "workbench.view.scm"
  },
  {
    "key": "cmd+s",
    "command": "git.stage",
    "when": "focusedView == 'workbench.scm'"
  },
  {
    "key": "cmd+d s",
    "command": "runCommands",
    "args": {
      "commands": [
        "git.stage",
        "workbench.action.closeActiveEditor",
        "workbench.view.scm",
        "list.focusDown",
        "list.select"
      ]
    },
    "when": "!operationInProgress"
  },
  {
    "key": "cmd+d m",
    "command": "dotfilesGit.compareWithMaster",
    "when": "!operationInProgress"
  },
  {
    "key": "cmd+shift+i",
    "command": "runCommands",
    "args": {
      "commands": [
        "git.stage",
        "workbench.action.closeActiveEditor",
        "workbench.view.scm",
        "list.focusDown",
        "list.select"
      ]
    },
    "when": "!operationInProgress"
  },
  {
    "key": "ctrl+j",
    "command": "workbench.action.compareEditor.nextChange",
    "when": "textCompareEditorVisible"
  },
  {
    "key": "cmd+j",
    "command": "workbench.action.compareEditor.nextChange",
    "when": "textCompareEditorVisible"
  },
  {
    "key": "cmd+r",
    "command": "workbench.action.compareEditor.nextChange",
    "when": "textCompareEditorVisible"
  },
  {
    "key": "ctrl+k",
    "command": "workbench.action.compareEditor.previousChange",
    "when": "textCompareEditorVisible"
  },
  {
    "key": "cmd+k",
    "command": "workbench.action.compareEditor.previousChange",
    "when": "textCompareEditorVisible"
  },
  {
    "key": "cmd+e",
    "command": "workbench.action.compareEditor.previousChange",
    "when": "textCompareEditorVisible"
  },
  {
    "key": "cmd+t",
    "command": "diffEditor.toggleCollapseUnchangedRegions",
    "when": "inDiffEditor || inMultiDiffEditor"
  },
  {
    "key": "cmd+shift+d",
    "command": "dotfilesGit.toggleDiffSideBySide",
    "when": "inDiffEditor || inMultiDiffEditor"
  },
  {
    "key": "cmd+shift+r",
    "command": "workbench.action.files.revert",
    "when": "editorTextFocus"
  },
  {
    "key": "cmd+o",
    "command": "git.openFile",
    "when": "textCompareEditorVisible || inDiffEditor || inMultiDiffEditor"
  },
  {
    "key": "cmd+o",
    "command": "dotfilesGit.openGitGraphWorkspaceFile",
    "when": "isInDiffEditor && resourceScheme == git-graph"
  },
  {
    "key": "cmd+shift+l",
    "command": "chatgpt.addToThread",
    "when": "editorTextFocus || textCompareEditorVisible || inDiffEditor || inMultiDiffEditor"
  },
  {
    "key": "cmd+=",
    "command": "chatgpt.addToThread",
    "when": "editorTextFocus || textCompareEditorVisible || inDiffEditor || inMultiDiffEditor"
  }
]
