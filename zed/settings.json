{
  "cli_default_open_behavior": "new_window",
  "diff_view_style": "unified",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "terminal": {
    "dock": "right"
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
  },
  "lsp": {
    "kotlin-lsp": {
      "binary": {
        "path": "/Users/praveen/Library/Application Support/Zed/extensions/work/kotlin/kotlin-lsp-262.2310.0/kotlin-lsp.sh",
        "arguments": ["--stdio"],
      },
    },
  },
  "agent": {
    "dock": "right",
    "default_model": {
      "provider": "google",
      "model": "gemini-2.5-flash",
      "enable_thinking": true,
