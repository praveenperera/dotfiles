    "favorite_models": [
      {
        "provider": "openai",
        "model": "gpt-5.4",
        "enable_thinking": false,
      },
    ],
    "model_parameters": [],
  },
  "auto_install_extensions": {
    "dockerfile": true,
    "html": true,
    "just": true,
    "kotlin": true,
    "package-swift-lsp": true,
    "swift": true,
  },
  "edit_predictions": {
    "provider": "zed",
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 13.0,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark",
