[
  {
    "context": "Editor && vim_mode != insert && !menu",
    "use_key_equivalents": true,
    "bindings": {
      "space f i": "buffer_search::Deploy",
      "space f f": "file_finder::Toggle",
      "space f s": "outline::Toggle",
      "space f shift-s": "project_symbols::Toggle",
      "space l a": "editor::ToggleCodeActions",
      "space l d": "editor::Hover",
      "space l shift-d": "editor::ToggleDiagnostics",
      "space l f": "editor::Format",
      "space l h": "editor::ShowSignatureHelp",
      "space l r": "editor::Rename",
      "space l shift-r": "editor::FindAllReferences",
      "space l s": "outline::Toggle",
      "space l shift-g": "project_symbols::Toggle",
      "space l x": "editor::RestartLanguageServer",
      "space u h": "editor::ToggleInlayHints",
      "space u shift-question": "editor::ToggleAutoSignatureHelp",
      "space t a": ["task::Spawn", { "task_name": "oca" }],
      "space t o": "terminal_panel::ToggleFocus",
      "space t shift-o": "terminal_panel::Toggle",
      "space w": "workspace::Save",
      "alt-shift-h": "vim::ResizePaneLeft",
      "alt-shift-j": "vim::ResizePaneDown",
      "alt-shift-k": "vim::ResizePaneUp",
      "alt-shift-l": "vim::ResizePaneRight"
    }
  },
  {
    "context": "Editor && !menu",
    "use_key_equivalents": true,
    "bindings": {
      "alt-shift-h": "vim::ResizePaneLeft",
      "alt-shift-j": "vim::ResizePaneDown",
      "alt-shift-k": "vim::ResizePaneUp",
      "alt-shift-l": "vim::ResizePaneRight",
      "ctrl-alt-h": ["workspace::IncreaseOpenDocksSize", { "px": 0 }],
      "ctrl-alt-l": ["workspace::DecreaseOpenDocksSize", { "px": 0 }]
    }
  },
  {
    "context": "Editor && vim_mode == normal && !menu",
    "use_key_equivalents": true,
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-h": "workspace::ActivatePaneLeft",
      "alt-j": "workspace::ActivatePaneDown",
      "alt-k": "workspace::ActivatePaneUp",
      "alt-l": "workspace::ActivatePaneRight",
      "alt-shift-h": "vim::ResizePaneLeft",
      "alt-shift-j": "vim::ResizePaneDown",
      "alt-shift-k": "vim::ResizePaneUp",
      "alt-shift-l": "vim::ResizePaneRight",
      "cmd-shift-d": "pane::SplitDown",
      "ctrl-`": "workspace::ToggleRightDock",
      "ctrl-shift-`": "workspace::ToggleBottomDock"
    }
  }
]
