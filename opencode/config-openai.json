{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "provider": {
    "openai": {
      "models": {
        "gpt-5.5-fast-plan": {
          "id": "gpt-5.5-fast",
          "name": "GPT-5.5 Fast",
          "options": {
            "reasoningEffort": "high"
          }
        },
        "gpt-5.5-fast-build": {
          "id": "gpt-5.5-fast",
          "name": "GPT-5.5 Fast",
          "options": {
            "reasoningEffort": "low"
          }
        }
      }
    }
  },
  "agent": {
    "plan": {
      "model": "openai/gpt-5.5-fast-plan",
      "variant": "high"
    },
    "build": {
      "model": "openai/gpt-5.5-fast-build",
      "variant": "low"
    }
  }
}
